{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.polar.PolarBleSdk\/documentation\/PolarBleSdk\/Data_PbExerciseRouteSamples2"},"sections":[],"abstract":[{"type":"text","text":"Route samples of the exercise."},{"type":"text","text":" "},{"type":"text","text":"Route is encoded in delta-format, that is, by using reference points (“Sync points”)"},{"type":"text","text":" "},{"type":"text","text":"and number of incremental changes to those points."}],"hierarchy":{"paths":[["doc:\/\/com.polar.PolarBleSdk\/documentation\/PolarBleSdk"]]},"topicSections":[{"identifiers":["doc:\/\/com.polar.PolarBleSdk\/documentation\/PolarBleSdk\/Data_PbExerciseRouteSamples2\/init()"],"anchor":"Initializers","generated":true,"title":"Initializers"},{"identifiers":["doc:\/\/com.polar.PolarBleSdk\/documentation\/PolarBleSdk\/Data_PbExerciseRouteSamples2\/unknownFields"],"anchor":"Instance-Properties","generated":true,"title":"Instance Properties"},{"identifiers":["doc:\/\/com.polar.PolarBleSdk\/documentation\/PolarBleSdk\/Data_PbExerciseRouteSamples2\/Equatable-Implementations","doc:\/\/com.polar.PolarBleSdk\/documentation\/PolarBleSdk\/Data_PbExerciseRouteSamples2\/Message-Implementations"],"anchor":"Default-Implementations","generated":true,"title":"Default Implementations"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Data_PbExerciseRouteSamples2"}],"platforms":["iOS","iPadOS","Mac Catalyst"]}]},{"content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The data format is optimized to give as small as possible changes for each new coordinate"},{"type":"text","text":" "},{"type":"text","text":"so that the Google Protocol Buffers delta coding can squeeze the data as small as possible."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The usage of Sync Points gives possibility and flexibility to reconfigure the stream during"},{"type":"text","text":" "},{"type":"text","text":"the packing if the conditions change."}]},{"level":2,"anchor":"Real-data-at-point-x-since-given-sync-point-can-be-calculated-by","type":"heading","text":"Real data at point x since given sync point can be calculated by:"},{"type":"paragraph","inlineContent":[{"type":"text","text":"latitude[x]  = sync_point->latitude  +"},{"type":"text","text":" "},{"type":"text","text":"SUM n=0..x ((sync_point->coordinate_granularity * latitude(n))* .000000001)"},{"type":"text","text":" "},{"type":"text","text":"longitude[x] = sync_point->longitude +"},{"type":"text","text":" "},{"type":"text","text":"SUM n=0..x ((sync_point->coordinate_granularity * longitude(n))* .000000001)"},{"type":"text","text":" "},{"type":"text","text":"timestamp[x] = sync_point->gps_date_time +"},{"type":"text","text":" "},{"type":"text","text":"SUM n=0..x (sync_point->timestamp_granularity * timestamp(n))"},{"type":"text","text":" "},{"type":"text","text":"altitude[x]  = sync_point->altitude  +"},{"type":"text","text":" "},{"type":"text","text":"SUM n=0..x (sync_point->altitude_granularity * altitude(n))"}]},{"type":"paragraph","inlineContent":[{"text":"To get data for any arbitrary point you need to iterate with given formula over all","type":"text"},{"text":" ","type":"text"},{"text":"previous synchronization points.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For the sample indexes which have also sync points, the result values are calculated","type":"text"},{"text":" ","type":"text"},{"text":"using the NEW sync point.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Datapoints without GPS FIX are not saved. The fixless-time can be seen from the timestamps","type":"text"},{"text":" ","type":"text"},{"text":"moving forward.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/polarblesdk\/data_pbexerciseroutesamples2"]}],"relationshipsSections":[{"identifiers":["doc:\/\/com.polar.PolarBleSdk\/s8CopyableP","doc:\/\/com.polar.PolarBleSdk\/s28CustomDebugStringConvertibleP","doc:\/\/com.polar.PolarBleSdk\/SQ","doc:\/\/com.polar.PolarBleSdk\/s9EscapableP","doc:\/\/com.polar.PolarBleSdk\/SH","doc:\/\/com.polar.PolarBleSdk\/s8SendableP","doc:\/\/com.polar.PolarBleSdk\/s16SendableMetatypeP","doc:\/\/com.polar.PolarBleSdk\/13SwiftProtobuf7MessageP"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"symbolKind":"struct","externalID":"s:11PolarBleSdk28Data_PbExerciseRouteSamples2V","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Data_PbExerciseRouteSamples2"}],"role":"symbol","roleHeading":"Structure","navigatorTitle":[{"kind":"identifier","text":"Data_PbExerciseRouteSamples2"}],"title":"Data_PbExerciseRouteSamples2","modules":[{"name":"PolarBleSdk"}]},"kind":"symbol","references":{"doc://com.polar.PolarBleSdk/s8CopyableP":{"title":"Swift.Copyable","type":"unresolvable","identifier":"doc:\/\/com.polar.PolarBleSdk\/s8CopyableP"},"doc://com.polar.PolarBleSdk/documentation/PolarBleSdk/Data_PbExerciseRouteSamples2/Message-Implementations":{"identifier":"doc:\/\/com.polar.PolarBleSdk\/documentation\/PolarBleSdk\/Data_PbExerciseRouteSamples2\/Message-Implementations","abstract":[],"role":"collectionGroup","title":"Message Implementations","url":"\/documentation\/polarblesdk\/data_pbexerciseroutesamples2\/message-implementations","type":"topic","kind":"article"},"doc://com.polar.PolarBleSdk/s9EscapableP":{"title":"Swift.Escapable","type":"unresolvable","identifier":"doc:\/\/com.polar.PolarBleSdk\/s9EscapableP"},"doc://com.polar.PolarBleSdk/s16SendableMetatypeP":{"title":"Swift.SendableMetatype","type":"unresolvable","identifier":"doc:\/\/com.polar.PolarBleSdk\/s16SendableMetatypeP"},"doc://com.polar.PolarBleSdk/SH":{"titl