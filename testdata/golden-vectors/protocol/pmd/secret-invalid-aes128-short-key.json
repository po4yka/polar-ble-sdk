{
  "id": "pmd-secret-invalid-aes128-short-key",
  "area": "pmd-secret",
  "case": "aes128_rejects_non_16_byte_key",
  "source": "Android PmdSecret and iOS PmdSecret characterization",
  "input": {
    "operation": "construct",
    "strategy": "AES128",
    "keyHex": "000102030405060708090a0b0c0d0e"
  },
  "expected": {
    "commonDecision": "AES128 must reject every key length except 16 bytes."
  },
  "platformExpectations": {
    "android": {
      "constructorError": "illegalArgumentException"
    },
    "ios": {
      "constructorError": "gattSecurityError"
    }
  },
  "platforms": {
    "android": true,
    "ios": true,
    "common": true
  },
  "notes": "Fifteen-byte AES-128 key is invalid.",
  "consumerTests": {
    "android": [
      "com.polar.androidcommunications.api.ble.model.gatt.client.pmd.PmdSecretTest"
    ],
    "ios": [
      "PmdSecretTest"
    ],
    "commonPrototype": [
      "com.polar.sharedtest.PmdSecretCommonPolicyTest"
    ]
  }
}
