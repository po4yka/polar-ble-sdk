{
  "id": "clear-remove-missing-and-fetch-none",
  "area": "sdk-atomic-set",
  "case": "clear_remove_missing_and_fetch_none",
  "source": "Android AtomicSetTest characterization",
  "input": {
    "operations": [
      {
        "op": "add",
        "value": "item1",
        "expectedReturn": true
      },
      {
        "op": "add",
        "value": "item2",
        "expectedReturn": true
      },
      {
        "op": "remove",
        "value": null
      },
      {
        "op": "remove",
        "value": "missing"
      },
      {
        "op": "snapshot",
        "name": "beforeClear"
      },
      {
        "op": "clear"
      }
    ]
  },
  "expected": {
    "migrationOwnership": "Shared PolarAtomicSet owns collection-like set semantics as a compatibility fixture; Android AtomicSet remains the synchronized platform wrapper and BLE/GATT observer primitive.",
    "size": 0,
    "accessAllOrder": [],
    "fetchPrefix": "item",
    "fetched": null,
    "contains": {
      "item1": false,
      "item2": false,
      "missing": false
    },
    "snapshots": {
      "beforeClear": ["item1", "item2"]
    }
  },
  "consumerTests": {
    "android": [
      "com.polar.androidcommunications.common.ble.AtomicSetTest"
    ],
    "commonPrototype": [
      "com.polar.sharedtest.AtomicSetCommonPolicyTest"
    ]
  },
  "platforms": {
    "android": true,
    "ios": false,
    "common": true
  },
  "notes": "Shared PolarAtomicSet and Android AtomicSet treat remove(null) and remove(missing) as no-ops, clear empties the set, and fetch returns null when no item matches; Android owns synchronization and platform observer usage."
