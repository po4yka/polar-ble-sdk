{
  "id": "workflow-runtime-policy",
  "area": "sdk.firmware-update",
  "case": "workflow_runtime_policy",
  "source": "Firmware update public workflow fake-transport planning vector",
  "input": {
    "kind": "firmwareWorkflowRuntimePolicy",
    "scenarios": [
      {
        "id": "check-update-not-available",
        "deviceInfo": {
          "firmwareVersion": "1.2.0",
          "modelName": "Model",
          "hardwareCode": "00112233.01"
        },
        "serverResponse": {
          "availableVersion": null,
          "fileUrl": null
        },
        "expectedStatuses": [
          "checkFwUpdateNotAvailable"
        ]
      },
      {
        "id": "check-update-available",
        "deviceInfo": {
          "firmwareVersion": "1.2.0",
          "modelName": "Model",
          "hardwareCode": "00112233.01"
        },
        "serverResponse": {
          "availableVersion": "1.3.0",
          "fileUrl": "https://firmware.example.invalid/fw-1.3.0.zip"
        },
        "expectedStatuses": [
          "checkFwUpdateAvailable"
        ]
      },
      {
        "id": "download-failure",
        "serverResponse": {
          "availableVersion": "1.3.0",
          "fileUrl": "https://firmware.example.invalid/fw-1.3.0.zip"
        },
        "packageDownload": "throws",
        "expectedTerminalStatus": "fwUpdateFailed"
      },
      {
        "id": "retryable-server-failure",
        "serverResponse": {
          "status": 503,
          "retryable": true
        },
        "expectedStatuses": [
          "fwUpdateFailed"
        ],
        "expectedTerminalError": "retryable-server-failure",
        "downloadAttempted": false
      },
      {
        "id": "client-request-failure",
        "serverResponse": {
          "status": 400,
          "retryable": false
        },
        "expectedStatuses": [
          "fwUpdateFailed"
        ],
        "expectedTerminalError": "client-request-failure",
        "downloadAttempted": false
      },
      {
        "id": "empty-or-invalid-zip",
        "serverResponse": {
          "availableVersion": "1.3.0",
          "fileUrl": "https://firmware.example.invalid/fw-1.3.0.zip"
        },
        "packageDownload": "bytes",
        "zipExtraction": "empty-or-invalid",
        "expectedTerminalStatus": "fwUpdateNotAvailable"
      },
      {
        "id": "cancel-after-package-fetch-cleans-up-before-ble-write",
        "serverResponse": {
          "availableVersion": "1.3.0",
          "fileUrl": "https://firmware.example.invalid/fw-1.3.0.zip"
        },
        "packageDownload": "bytes",
        "zipExtraction": "valid",
        "cancellationPoint": "afterPackageFetch",
        "expectedStatuses": [
          "fetchingFwUpdatePackage",
          "fwUpdateCancelled"
        ],
        "expectedWrites": [],
        "expectedCleanupCallbackCount": 1,
        "expectedTerminalError": "cancelled"
      },
      {
        "id": "write-package-success-with-system-update-last",
        "firmwareFiles": [
          {
            "name": "BTUPDAT.BIN",
            "payloadHex": "01020304"
          },
          {
            "name": "SYSUPDAT.IMG",
            "payloadHex": "05060708"
          }
        ],
        "expectedWriteOrder": [
          "/BTUPDAT.BIN",
          "/SYSUPDAT.IMG"
        ],
        "expectedStatusOrder": [
          "preparingDeviceForFwUpdate",
          "fetchingFwUpdatePackage",
          "writingFwUpdatePackage",
          "finalizingFwUpdate",
          "fwUpdateCompletedSuccessfully"
        ]
      },
      {
        "id": "system-update-reboot-response-is-success",
        "firmwareFiles": [
          {
            "name": "SYSUPDAT.IMG",
            "payloadHex": "05060708"
          }
        ],
        "writeTerminalError": {
          "pftpError": "rebooting"
        },
        "expectedTerminalStatus": "fwUpdateCompletedSuccessfully"
      },
      {
        "id": "non-system-reboot-response-is-terminal-failure",
        "firmwareFiles": [
          {
            "name": "BTUPDAT.BIN",
            "payloadHex": "01020304"
          }
        ],
        "writeTerminalError": {
          "pftpError": "rebooting"
        },
        "expectedTerminalError": "propagate-error"
      },
      {
        "id": "battery-too-low-response-is-terminal-failure",
        "firmwareFiles": [
          {
            "name": "SYSUPDAT.IMG",
            "payloadHex": "05060708"
          }
        ],
        "writeTerminalError": {
          "pftpError": "batteryTooLow"
        },
        "expectedTerminalError": "battery-too-low"
      }
    ]
  },
  "expected": {
