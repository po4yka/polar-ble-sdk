{
  "id": "capability-boolean-flags",
  "area": "sdk.device-capabilities",
  "case": "firmware_activity_sensor_lookup",
  "source": "Android BlePolarDeviceCapabilitiesUtilityTest and iOS PolarBleApiImplTests characterization before shared capability parsing shared ownership",
  "input": {
    "kind": "deviceCapabilityLookup",
    "config": {
      "version": "capability-vector-flags-1",
      "devices": {
        "h10": {
          "fileSystemType": "H10_FILE_SYSTEM",
          "recordingSupported": true,
          "firmwareUpdateSupported": false,
          "activityDataSupported": false,
          "isDeviceSensor": true
        },
        "ignite3": {
          "fileSystemType": "POLAR_FILE_SYSTEM_V2",
          "recordingSupported": false,
          "firmwareUpdateSupported": true,
          "activityDataSupported": true,
          "isDeviceSensor": false
        },
        "partial": {
          "fileSystemType": "POLAR_FILE_SYSTEM_V2",
          "recordingSupported": false,
          "firmwareUpdateSupported": false
        }
      },
      "defaults": {
        "fileSystemType": "POLAR_FILE_SYSTEM_V2",
        "recordingSupported": true,
        "firmwareUpdateSupported": true,
        "activityDataSupported": true,
        "isDeviceSensor": false
      }
    },
    "queries": [
      "h10",
      "H10",
      "ignite3",
      "partial",
      "unknown-device"
    ]
  },
  "expected": {
