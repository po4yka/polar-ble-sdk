  "consumerTests": {
    "android": [
      "com.polar.androidcommunications.api.ble.model.polar.BlePolarDeviceCapabilitiesUtilityTest"
    ],
    "ios": [
      "PolarBleApiImplTests"
    ],
    "commonPrototype": [
      "com.polar.sharedtest.DeviceCapabilitiesCommonPolicyTest"
    ]
  },
  "notes": "This vector covers the portable capability boolean lookup fields exposed by both SDKs. Version-mismatch user-config merge behavior is covered by a sibling vector; app-resource override behavior remains platform-owned until common resource loading is deliberately introduced."
