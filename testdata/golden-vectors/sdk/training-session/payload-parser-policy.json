            "sport=5"
          ]
        },
        {
          "id": "route-protobuf",
          "parser": "PbExerciseRouteSamples",
          "encoding": "protobuf",
          "publicModelSlot": "route",
          "fields": [
            "latitude=10",
            "longitude=20",
            "satelliteAmount=6"
          ]
        },
        {
          "id": "route-gzip-protobuf",
          "parser": "PbExerciseRouteSamples",
