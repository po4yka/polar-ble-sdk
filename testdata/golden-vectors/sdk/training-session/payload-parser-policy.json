{
  "id": "payload-parser-policy",
  "area": "sdk.training-session",
  "case": "payload_parser_policy",
  "source": "Android and iOS PolarTrainingSessionUtils byte-level protobuf characterization distilled into shared parser migration policy after gzip payload decompression and selected field parsing moved to shared KMP",
  "description": "Pins the training-session protobuf and gzip-protobuf payload families whose selected field parsing is executable in common code while generated public protobuf model reconstruction remains platform-owned.",
  "input": {
    "kind": "payloadParserPolicy",
    "cases": [
      {
        "id": "training-session-summary-protobuf",
        "fileName": "TSESS.BPB",
        "parser": "PbTrainingSession",
        "encoding": "protobuf",
        "publicModelSlot": "sessionSummary",
        "expectedFields": [
          "start.year=2025",
          "exerciseCount=2",
          "modelName=Polar 360"
        ]
      },
      {
        "id": "exercise-summary-protobuf",
        "fileName": "BASE.BPB",
        "parser": "PbExerciseBase",
        "encoding": "protobuf",
        "publicModelSlot": "exerciseSummary",
        "expectedFields": [
          "start.hour=12",
          "walkingDistance=10000",
          "sport=5"
        ]
      },
      {
        "id": "route-protobuf",
        "fileName": "ROUTE.BPB",
        "parser": "PbExerciseRouteSamples",
        "encoding": "protobuf",
        "publicModelSlot": "route",
        "expectedFields": [
          "latitude=10",
          "longitude=20",
          "satelliteAmount=6"
        ]
      },
      {
        "id": "route-gzip-protobuf",
        "fileName": "ROUTE.GZB",
        "parser": "PbExerciseRouteSamples",
        "encoding": "gzip-protobuf",
        "publicModelSlot": "route",
        "expectedFields": [
          "latitude=10",
          "longitude=20",
          "satelliteAmount=6"
        ]
      },
      {
        "id": "route-advanced-protobuf",
        "fileName": "ROUTE2.BPB",
        "parser": "PbExerciseRouteSamples2",
        "encoding": "protobuf",
        "publicModelSlot": "routeAdvanced",
        "expectedFields": [
          "syncPoint.index=0",
          "syncPoint.latitude=10",
          "syncPoint.longitude=20"
        ]
      },
      {
        "id": "route-advanced-gzip-protobuf",
        "fileName": "ROUTE2.GZB",
        "parser": "PbExerciseRouteSamples2",
        "encoding": "gzip-protobuf",
        "publicModelSlot": "routeAdvanced",
        "expectedFields": [
          "syncPoint.index=0",
          "syncPoint.latitude=10",
          "syncPoint.longitude=20"
        ]
      },
      {
        "id": "samples-protobuf",
        "fileName": "SAMPLES.BPB",
        "parser": "PbExerciseSamples",
        "encoding": "protobuf",
        "publicModelSlot": "samples",
        "expectedFields": [
          "recordingIntervalSeconds=1",
          "heartRateSamples=120,125,130",
          "speedSamples=2000,2100"
        ]
      },
      {
        "id": "samples-gzip-protobuf",
        "fileName": "SAMPLES.GZB",
        "parser": "PbExerciseSamples",
        "encoding": "gzip-protobuf",
        "publicModelSlot": "samples",
        "expectedFields": [
          "recordingIntervalSeconds=1",
          "heartRateSamples=120,125,130",
          "speedSamples=2000,2100"
        ]
      },
      {
        "id": "samples-advanced-gzip-protobuf",
        "fileName": "SAMPLES2.GZB",
        "parser": "PbExerciseSamples2",
        "encoding": "gzip-protobuf",
        "publicModelSlot": "samplesAdvanced",
        "expectedFields": [
          "sampleType=HEART_RATE",
          "recordingIntervalMs=1000",
          "heartRateSamples=131,132,133"
        ]
      }
    ]
  },
  "expected": {
    "commonParserPrototype": {
      "status": "executable shared parser-policy coverage; gzip decoding and selected protobuf field parsing are shared while generated public model reconstruction remains platform-owned",
      "cases": [
        {
          "id": "training-session-summary-protobuf",
          "parser": "PbTrainingSession",
          "encoding": "protobuf",
          "publicModelSlot": "sessionSummary",
