  "platformExpectations": {
    "android": {
      "syncStartQueryFailure": "returns false and sends no notifications",
      "syncStopNotificationFailure": "swallows the notification error after STOP_SYNC is attempted"
    },
    "ios": {
      "syncStartQueryFailure": "propagates the query error and sends no notifications",
      "syncStopNotificationFailure": "propagates the notification error after STOP_SYNC is attempted"
    },
    "commonDecision": "Keep sync failure policy platform-specific until the public API migration has an approved compatibility decision."
  },
