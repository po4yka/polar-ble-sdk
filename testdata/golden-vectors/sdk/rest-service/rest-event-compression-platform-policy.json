{
  "id": "rest-event-compression-platform-policy",
  "area": "sdk.rest-service",
  "case": "rest_event_compression_platform_policy",
  "source": "Android and iOS REST API characterization tests",
  "input": {
    "kind": "restEventCompression",
    "cases": [
      {
        "id": "uncompressed-batch",
        "uncompressed": true,
        "payloads": [
          "{\"path\":\"/v1/users\",\"operation\":\"created\"}",
          "{\"path\":\"/v1/users/1\",\"operation\":\"updated\"}"
        ]
      },
      {
        "id": "empty-uncompressed-batch",
        "uncompressed": true,
        "payloads": []
      },
      {
        "id": "compressed-batch",
        "uncompressed": false,
        "payloads": [
          "{\"path\":\"/v1/training\",\"operation\":\"synced\"}",
          "{\"path\":\"/v1/activity\",\"operation\":\"deleted\"}"
        ],
        "compressedPayloadsHex": {
          "android": [
            "1f8b0800000000000213ab562a482cc950b252d22f33d42f294acccccbcc4b57d251ca2f482d4a2cc9cccf034a1557e625a7a628d50200b2cff1c62c000000",
            "1f8b0800000000000213ab562a482cc950b252d22f33d44f4c2ec92ccb2ca954d251ca2f482d4a2cc9cccf034aa5a4e6a496a4a628d502005bcafdf42d000000"
          ]
        },
        "compression": {
          "android": "gzip",
          "ios": "deflate"
        }
      },
      {
        "id": "malformed-compressed-payload",
        "uncompressed": false,
        "payloads": [
          "not-a-compressed-rest-event"
        ],
        "compression": {
          "android": "invalid-gzip",
          "ios": "invalid-deflate"
        },
        "expected": {
          "android": "throws-ioexception",
          "ios": "emits-original-payload"
        }
      }
    ]
  },
  "expected": {
    "payloadPolicy": "emit-original-utf8-payloads",
    "batchPolicy": "preserve-notification-payload-order-and-emit-empty-batches",
    "malformedCompressedPayloadPolicy": {
      "android": "throws IOException from GZIPInputStream and terminates the flow collection",
      "ios": "logs inflate failure and emits the original payload bytes"
    }
  },
  "platformExpectations": {
    "commonDecision": {
      "compressionPolicy": "Shared KMP owns REST event compression dispatch while platform actuals deliberately preserve Android GZIPInputStream-compatible gzip decoding and iOS zlib inflate behavior."
    }
  },
  "platforms": {
    "android": true,
    "ios": true,
    "common": true
  },
  "notes": "REST API event notifications emit original payloads when uncompressed and inflate compressed payloads through shared KMP platform actual codecs that preserve the current Android gzip and iOS zlib behavior.",
  "consumerTests": {
    "android": [
      "com.polar.sdk.api.model.utils.PolarDeviceRestApiUtilsTest"
    ],
    "ios": [
      "PolarDeviceRestApiServiceTests"
    ],
    "commonPrototype": [
      "com.polar.sharedtest.RestEventCompressionPolicyCommonTest"
    ]
  }
}
