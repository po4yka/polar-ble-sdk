{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polarofficial.github.io/polar-ble-sdk/testdata/golden-vectors/schema/golden-vector.schema.json",
  "title": "Polar BLE SDK golden vector",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "area",
    "case",
    "source",
    "input",
    "expected",
    "consumerTests",
    "platforms"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "area": {
      "type": "string",
      "minLength": 1
    },
    "case": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9_]*$"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "input": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "hex": {
          "type": "string",
          "pattern": "^([0-9a-f]{2})*$"
        },
        "text": {
          "type": "string"
        },
        "json": {}
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": true
    },
    "consumerTests": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "android": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "ios": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "commonPrototype": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "android"
          ]
        },
        {
          "required": [
            "ios"
          ]
        },
        {
          "required": [
            "commonPrototype"
          ]
        }
      ]
    },
    "platformExpectations": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "android": {
          "type": "object",
          "additionalProperties": true
        },
        "ios": {
          "type": "object",
          "additionalProperties": true
        },
        "commonDecision": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": true
    },
    "commonDecision": {
      "type": "object",
      "additionalProperties": true
    },
    "platforms": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "android",
        "ios",
        "common"
      ],
      "properties": {
        "android": {
          "type": "boolean"
        },
        "ios": {
          "type": "boolean"
        },
        "common": {
          "type": "boolean"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
